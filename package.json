{
  "name": "panchito-enterprise-allboys",
  "version": "1.6.0",
  "description": "Panchito Enterprise - All Boys Asistente oficial",
  "author": "All Boys",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "app": "electron .",
    "dist": "electron-builder --win nsis portable",
    "dist:win": "electron-builder --win nsis portable",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ar.allboys.panchito.enterprise",
    "productName": "Panchito Enterprise",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "package.json",
      "public/**/*",
      "data/**/*",
      ".env.example",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Panchito Enterprise"
    },
    "portable": {
      "artifactName": "Panchito Enterprise Portable.exe"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "icon": "build/icon.icns"
    }
  }
}
